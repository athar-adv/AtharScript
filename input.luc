-- Lucy Programming Language: input.luc

import io "@std/io"

use io::{println as print}

public class Point
    public x: i32
    public y: i32
    
    public function new(x: ->i32, y: ->i32): &Self
        return &Self {x = x, y = y}
    end

    operator + (a: &Self, b: &Self): &Self
        return Self::new(
            a.x + b.x,
            a.y + b.y
        )
    end
end

function main(): empty
    local a = Point::new(3, 4)
    print(->a.x)
end
